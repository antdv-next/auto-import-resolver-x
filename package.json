{
  "name": "@antdv-next/auto-import-resolver-x",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.3",
  "description": "antdv-next x auto import resolver based on unplugin-vue-components",
  "license": "MIT",
  "author": "antdv-next",
  "keywords": [
    "antdv-next",
    "ant-design-vue",
    "vue",
    "unplugin",
    "unplugin-vue-components",
    "auto-import",
    "resolver",
    "components"
  ],
  "sideEffects": false,
  "homepage": "https://github.com/antdv-next/auto-import-resolver-x#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antdv-next/auto-import-resolver-x.git"
  },
  "bugs": {
    "url": "https://github.com/antdv-next/auto-import-resolver-x/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "generate": "esno scripts/generate.ts",
    "prepublishOnly": "pnpm build",
    "bump": "bumpp"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "unplugin-vue-components": ">=28.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@types/node": "^25.0.10",
    "@vue/tsconfig": "^0.8.1",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.1.0",
    "esno": "4.8.0",
    "tsdown": "^0.20.1",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^28.0.0",
    "vitest": "^4.0.17"
  }
}
